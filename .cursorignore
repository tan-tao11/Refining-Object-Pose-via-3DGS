# Exclude large data directories from Cursor indexing and file watching
# This prevents high CPU load from excessive disk I/O during file scanning

# Main data directories containing large datasets
# data
# data/
# data/**
dataset/
dataset1/
data/omni3d/
data/omni3d/**
data/omni3d_ARKitScenes/**
data/omni3d_KITTI/**
data/omni3d_Objectron/**
data/omni3d_sunrgbd/**
data/omni3d_data/**
**/data_all/**
# **/omni3d/**
**/train/**

# Visualization directories with many image files
vis/
vis/**

# Validation visualization images
vis_val/
vis_val/**

# Training logs and checkpoints
logs/
logs/**

# Model weights (large binary files)
weights/
weights/**

# PyTorch3D library (external dependency, no need to index)
pytorch3d/
pytorch3d/**

# Python cache files
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# OS generated files
.DS_Store
Thumbs.db

# IDE specific files
# .vscode/settings.json
# .vscode/launch.json

# Temporary files
*.tmp
*.temp
*.swp
*.bak

# Log files
*.log
# Note: data/omni3d/ folder is visible but subdirectories are excluded to prevent performance issues

# Git LFS objects and pack files (very large)
**/.git/lfs/**
**/.git/objects/pack/**
**/.git/**
**/.git
**/.git/config

# Large model files
*.pth
*.pt
*.safetensors
*.ckpt
*.bin

# Git subdirectories in large model directories
src/pose_estimation/models/**/.git/**
src/preprocess/Grounded-Segment-Anything/**/.git/**
